{
    "name": "awen/cella",
    "description": "Self-hostable infrastructure for Cardano Constitutional Committee governance: ingest governance actions, review constitutionality, deliberate, vote, and submit rationale on-chain.",
    "type": "project",
    "license": "Apache-2.0",
    "homepage": "https://github.com/Awen-online/cella",
    "support": {
        "issues": "https://github.com/Awen-online/cella/issues",
        "source": "https://github.com/Awen-online/cella"
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Awen\\Cella\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Awen\\Cella\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "find src -name '*.php' -print0 | xargs -0 -n1 php -l"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
