# Cella configuration — every value is optional; sensible defaults are built in.
# Copy to .env and adjust as needed (or just export these in your shell).

# Path to the SQLite database file (created on first run).
CELLA_DB=cella.db

# Web server listen address.
CELLA_ADDR=:8080

# Koios API base URL (mainnet by default). For Preprod/Preview, point this at
# the corresponding Koios instance.
KOIOS_URL=https://api.koios.rest/api/v1

# Optional Koios bearer token for higher rate limits (not required).
# KOIOS_TOKEN=

# Signs the session cookies that carry a delegate's identity. Leave it unset and
# Cella generates a random key at startup — secure, but sessions are dropped on
# every restart. Set it to a long random string for any persistent deployment,
# and keep it secret: anyone holding it can mint a session as any delegate.
# CELLA_SECRET=
